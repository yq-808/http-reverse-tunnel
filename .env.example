# Remote SSH host that will expose a reverse-forwarded HTTP port.
TUNNEL_SSH_USER=root
TUNNEL_SSH_HOST=47.112.6.140
TUNNEL_SSH_KEY_PATH=~/.ssh/id_ed25519

# Remote listening endpoint.
TUNNEL_REMOTE_BIND_HOST=127.0.0.1
TUNNEL_REMOTE_PORT=8787

# Local HTTP target endpoint to forward to.
TUNNEL_LOCAL_HOST=127.0.0.1
TUNNEL_LOCAL_PORT=8787

# SSH keepalive settings.
TUNNEL_SERVER_ALIVE_INTERVAL=30
TUNNEL_SERVER_ALIVE_COUNT_MAX=3

# Auto reconnect + HTTP health check through the tunnel.
TUNNEL_HEALTH_ENABLED=1
TUNNEL_HEALTH_PATH=/healthz
TUNNEL_HEALTH_TIMEOUT=5
TUNNEL_HEALTH_CHECK_INTERVAL=15
TUNNEL_HEALTH_MAX_FAILURES=3
TUNNEL_RECONNECT_DELAY=2
